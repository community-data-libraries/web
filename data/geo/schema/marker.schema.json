{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://community-data-libraries.org/schema/marker.schema.json",
  "title": "CDL Geo Marker Properties",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "category"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Stable slug identifier (lowercase, hyphens)."
    },
    "name": { "type": "string", "minLength": 1 },
    "category": {
      "type": "string",
      "enum": ["dataset", "site", "organization", "event", "other"]
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "region": {
      "type": "string",
      "description": "ISO 3166-1 alpha-2 code or region label",
      "pattern": "^[A-Z]{2}|[A-Za-z0-9 -]+$"
    },
    "sourceUrl": { "type": "string", "format": "uri" },
    "updatedAt": { "type": "string", "format": "date-time" }
  }
}
