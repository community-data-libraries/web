---
import Layout from '@layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { extractThemes } from '@lib/data/libraryAccess';

const resources = await getCollection('master-library');
const dataThemes = extractThemes(resources, 'student');
---

<Layout
  title="Student"
  description="Learning resources and tools for students building data skills and projects."
>
  <section class="role-shell">
    <h1>Student</h1>
    <p>
      Discover beginner-friendly tools, datasets, and guides for coursework, capstones, and
      portfolio projects.
    </p>

    <article class="panel">
      <h2>Data Themes</h2>
      <ul>
        {dataThemes.map((theme) => (
          <li>{theme}</li>
        ))}
      </ul>
    </article>

    <p class="notice">
      Some sensitive datasets are intentionally unavailable in student view (for example, opioid
      addiction data themes).
    </p>

    <p class="role-link">
      Open <a href="/web/master-library?audience=student">Master Library</a> with student visibility.
    </p>
  </section>

  <style>
    .role-shell {
      display: grid;
      gap: var(--space-6);
    }

    .panel {
      border: 1px solid var(--color-border);
      background: var(--color-surface);
      border-radius: var(--radius-lg);
      padding: var(--space-6);
    }

    .panel h2 {
      margin-bottom: var(--space-3);
      font-size: var(--font-size-xl);
    }

    .panel ul {
      margin: 0;
      padding-left: 1.25rem;
      display: grid;
      gap: var(--space-2);
    }

    .notice {
      border-left: 4px solid var(--color-primary);
      background: var(--color-surface);
      border-radius: var(--radius-sm);
      padding: var(--space-4);
      margin: 0;
    }

    .role-link {
      margin: 0;
      color: var(--color-text-muted);
    }
  </style>
</Layout>
