---
import Layout from '@layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { audienceLabel, canAudienceAccess, type AudienceRole } from '@lib/data/libraryAccess';

const resources = await getCollection('master-library');
const rawAudience = Astro.url.searchParams.get('audience');
const audience: AudienceRole =
  rawAudience === 'teacher' || rawAudience === 'student' || rawAudience === 'community'
    ? rawAudience
    : 'community';

const visibleResources = resources.filter((resource) => canAudienceAccess(resource, audience));

const selectedCategory = (Astro.url.searchParams.get('category') ?? '').trim();
const selectedTag = (Astro.url.searchParams.get('tag') ?? '').trim();
const query = (Astro.url.searchParams.get('q') ?? '').trim();
const sort = Astro.url.searchParams.get('sort') ?? 'updated';

const searchQuery = query.toLowerCase();

const allThemes = Array.from(
  new Set(
    visibleResources.flatMap((resource) =>
      resource.data.dataThemes.length > 0 ? resource.data.dataThemes : resource.data.tags,
    ),
  ),
).sort((left, right) => left.localeCompare(right));

const allTags = Array.from(new Set(visibleResources.flatMap((resource) => resource.data.tags))).sort((left, right) =>
  left.localeCompare(right),
);

const filteredResources = visibleResources.filter((resource) => {
  const themes = resource.data.dataThemes.length > 0 ? resource.data.dataThemes : resource.data.tags;
  const matchesCategory = selectedCategory ? themes.includes(selectedCategory) : true;
  const matchesTag = selectedTag ? resource.data.tags.includes(selectedTag) : true;
  const haystack = [resource.data.title, resource.data.description, ...themes, ...resource.data.tags]
    .join(' ')
    .toLowerCase();
  const matchesSearch = searchQuery ? haystack.includes(searchQuery) : true;
  return matchesCategory && matchesTag && matchesSearch;
});

const sortedResources = [...filteredResources].sort((left, right) => {
  if (sort === 'title') {
    return left.data.title.localeCompare(right.data.title);
  }

  if (sort === 'featured') {
    return Number(right.data.featured) - Number(left.data.featured);
  }

  const leftTime = left.data.publishedDate ? new Date(left.data.publishedDate).getTime() : 0;
  const rightTime = right.data.publishedDate ? new Date(right.data.publishedDate).getTime() : 0;
  return rightTime - leftTime;
});

const featuredResources = sortedResources.filter((resource) => resource.data.featured).slice(0, 2);
const listResources = sortedResources.filter(
  (resource) => !featuredResources.some((featured) => featured.id === resource.id),
);

const typeCounts = visibleResources.reduce(
  (accumulator, resource) => {
    accumulator[resource.data.category] += 1;
    return accumulator;
  },
  {
    dataset: 0,
    tool: 0,
    guide: 0,
    paper: 0,
  },
);

const clearFiltersHref = `/web/master-library?audience=${audience}`;
const activeFilters = [
  selectedCategory ? `Theme: ${selectedCategory}` : '',
  selectedTag ? `Tag: ${selectedTag}` : '',
  query ? `Search: ${query}` : '',
].filter(Boolean);

function audienceHref(nextAudience: AudienceRole): string {
  const params = new URLSearchParams();
  params.set('audience', nextAudience);
  if (selectedCategory) params.set('category', selectedCategory);
  if (selectedTag) params.set('tag', selectedTag);
  if (query) params.set('q', query);
  if (sort) params.set('sort', sort);
  return `/web/master-library?${params.toString()}`;
}

function formatDate(date: Date | undefined): string {
  if (!date) return 'Not specified';
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<Layout title="Master Library" description="All curated resources in the CDL master library">
  <section class="library-page">
    <aside class="sidebar">
      <h2>Filters</h2>
      <form method="get" action="/web/master-library" class="filters-form">
        <input type="hidden" name="audience" value={audience} />

        <label>
          <span>Search</span>
          <input type="search" name="q" value={query} placeholder="Search title, description, or themes" />
        </label>

        <label>
          <span>Theme</span>
          <select name="category">
            <option value="">All themes</option>
            {allThemes.map((theme) => (
              <option value={theme} selected={selectedCategory === theme}>{theme}</option>
            ))}
          </select>
        </label>

        <label>
          <span>Tag</span>
          <select name="tag">
            <option value="">All tags</option>
            {allTags.map((tag) => (
              <option value={tag} selected={selectedTag === tag}>{tag}</option>
            ))}
          </select>
        </label>

        <label>
          <span>Sort</span>
          <select name="sort">
            <option value="updated" selected={sort === 'updated'}>Most recent</option>
            <option value="featured" selected={sort === 'featured'}>Featured first</option>
            <option value="title" selected={sort === 'title'}>A-Z</option>
          </select>
        </label>

        <div class="filter-actions">
          <button type="submit" class="button">Apply</button>
          <a href={clearFiltersHref} class="reset-link">Reset</a>
        </div>
      </form>

      <section class="type-panel">
        <h3>Resource Types</h3>
        <ul>
          <li><span>Datasets</span><strong>{typeCounts.dataset}</strong></li>
          <li><span>Guides</span><strong>{typeCounts.guide}</strong></li>
          <li><span>Tools</span><strong>{typeCounts.tool}</strong></li>
          <li><span>Papers</span><strong>{typeCounts.paper}</strong></li>
        </ul>
      </section>
    </aside>

    <div class="content">
      <header class="content-header">
        <div>
          <h1>Master Library</h1>
          <p>
            Showing <strong>{audienceLabel(audience)}</strong> view.
            {audience !== 'teacher' && ' Sensitive datasets are excluded.'}
          </p>
        </div>
        <div class="audience-switch">
          <a href={audienceHref('teacher')} class={audience === 'teacher' ? 'active' : undefined}>Teacher</a>
          <a href={audienceHref('student')} class={audience === 'student' ? 'active' : undefined}>Student</a>
          <a href={audienceHref('community')} class={audience === 'community' ? 'active' : undefined}>Community</a>
        </div>
      </header>

      <div class="results-head">
        <p><strong>{sortedResources.length}</strong> resources</p>
        {activeFilters.length > 0 && <a href={clearFiltersHref}>Clear active filters</a>}
      </div>

      {activeFilters.length > 0 && (
        <div class="active-filters" aria-label="Active filters">
          {activeFilters.map((item) => (
            <span class="chip">{item}</span>
          ))}
        </div>
      )}

      {featuredResources.length > 0 && (
        <section class="featured">
          <h2>Featured</h2>
          <div class="featured-grid">
            {featuredResources.map((resource) => (
              <article class="featured-card">
                <h3>
                  {resource.data.url ? (
                    <a href={resource.data.url} target="_blank" rel="noopener noreferrer">{resource.data.title}</a>
                  ) : (
                    resource.data.title
                  )}
                </h3>
                <p>{resource.data.description}</p>
                <p class="meta-line">Updated {formatDate(resource.data.publishedDate)}</p>
              </article>
            ))}
          </div>
        </section>
      )}

      <section class="results">
        <h2>All Resources</h2>
        {listResources.length === 0 ? (
          <article class="result-card empty"><p>No resources match your current filter combination.</p></article>
        ) : (
          listResources.map((resource) => {
            const themes = resource.data.dataThemes.length > 0 ? resource.data.dataThemes : resource.data.tags;
            return (
              <article class="result-card">
                <div class="result-main">
                  <h3>
                    {resource.data.url ? (
                      <a href={resource.data.url} target="_blank" rel="noopener noreferrer">{resource.data.title}</a>
                    ) : (
                      resource.data.title
                    )}
                  </h3>
                  <p>{resource.data.description}</p>
                  <div class="chips">
                    <span class="chip">{resource.data.category}</span>
                    {themes.slice(0, 3).map((theme) => (
                      <span class="chip">{theme}</span>
                    ))}
                    {audience === 'teacher' && resource.data.pedagogicalTags.slice(0, 2).map((tag) => (
                      <span class="chip chip-accent">{tag}</span>
                    ))}
                  </div>
                </div>
                <aside class="result-side">
                  <p><strong>Updated</strong></p>
                  <p>{formatDate(resource.data.publishedDate)}</p>
                  <p><strong>Difficulty</strong></p>
                  <p>{resource.data.difficulty ?? 'Not specified'}</p>
                </aside>
              </article>
            );
          })
        )}
      </section>
    </div>
  </section>

  <style>
    .library-page {
      display: grid;
      gap: var(--space-6);
      grid-template-columns: 1fr;
    }

    @media (min-width: 1024px) {
      .library-page {
        grid-template-columns: minmax(260px, 300px) 1fr;
        align-items: start;
      }
    }

    .sidebar {
      position: sticky;
      top: 86px;
      border: 1px solid var(--color-border);
      border-radius: var(--radius-lg);
      background: var(--color-surface);
      padding: var(--space-5);
      display: grid;
      gap: var(--space-5);
    }

    .sidebar h2 {
      margin: 0;
      font-size: var(--font-size-xl);
    }

    .filters-form {
      display: grid;
      gap: var(--space-4);
    }

    .filters-form label {
      display: grid;
      gap: var(--space-2);
    }

    .filters-form span {
      font-size: var(--font-size-sm);
      font-weight: 600;
    }

    .filters-form input,
    .filters-form select {
      width: 100%;
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      padding: var(--space-2) var(--space-3);
      background: var(--color-background);
      color: var(--color-text);
    }

    .filter-actions {
      display: flex;
      align-items: center;
      gap: var(--space-3);
    }

    .filter-actions .button {
      padding: var(--space-2) var(--space-4);
    }

    .reset-link {
      color: var(--color-text-muted);
      font-size: var(--font-size-sm);
    }

    .type-panel {
      border-top: 1px solid var(--color-border);
      padding-top: var(--space-4);
    }

    .type-panel h3 {
      margin: 0 0 var(--space-3);
      font-size: var(--font-size-base);
    }

    .type-panel ul {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      gap: var(--space-2);
    }

    .type-panel li {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: var(--font-size-sm);
      color: var(--color-text-muted);
    }

    .content {
      display: grid;
      gap: var(--space-5);
    }

    .content-header {
      display: grid;
      gap: var(--space-3);
    }

    .content-header h1 {
      margin-bottom: var(--space-2);
      font-size: clamp(var(--font-size-2xl), 2.1vw, var(--font-size-4xl));
    }

    .content-header p {
      margin: 0;
      color: var(--color-text-muted);
    }

    .audience-switch {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-2);
    }

    .audience-switch a {
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      padding: var(--space-2) var(--space-3);
      font-size: var(--font-size-sm);
      color: var(--color-text);
      text-decoration: none;
    }

    .audience-switch a.active {
      background: var(--color-primary);
      border-color: var(--color-primary);
      color: white;
    }

    .results-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-3);
      border-top: 1px solid var(--color-border);
      border-bottom: 1px solid var(--color-border);
      padding: var(--space-3) 0;
      color: var(--color-text-muted);
      font-size: var(--font-size-sm);
    }

    .results-head p {
      margin: 0;
    }

    .active-filters {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-2);
      margin-top: calc(var(--space-3) * -1);
    }

    .featured,
    .results {
      display: grid;
      gap: var(--space-3);
    }

    .featured h2,
    .results h2 {
      margin: 0;
      font-size: var(--font-size-xl);
    }

    .featured-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }

    @media (min-width: 900px) {
      .featured-grid {
        grid-template-columns: 1fr 1fr;
      }
    }

    .featured-card,
    .result-card {
      border: 1px solid var(--color-border);
      border-radius: var(--radius-lg);
      background: var(--color-surface);
      box-shadow: var(--shadow-sm);
    }

    .featured-card {
      padding: var(--space-5);
      display: grid;
      gap: var(--space-3);
    }

    .featured-card h3,
    .result-main h3 {
      margin: 0;
      font-size: var(--font-size-xl);
    }

    .featured-card p {
      margin: 0;
    }

    .meta-line {
      color: var(--color-text-muted);
      font-size: var(--font-size-sm);
    }

    .result-card {
      display: grid;
      grid-template-columns: 1fr;
    }

    @media (min-width: 900px) {
      .result-card {
        grid-template-columns: minmax(0, 1fr) 220px;
      }
    }

    .result-main {
      padding: var(--space-5);
      display: grid;
      gap: var(--space-3);
    }

    .result-main p {
      margin: 0;
      color: var(--color-text-muted);
    }

    .chips {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-2);
    }

    .chip {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: var(--space-1) var(--space-2);
      border-radius: 999px;
      border: 1px solid var(--color-border);
      font-size: var(--font-size-xs);
      color: var(--color-text-muted);
      background: color-mix(in srgb, var(--color-background) 92%, var(--color-primary) 8%);
    }

    .chip-accent {
      border-color: var(--color-primary);
      color: var(--color-primary);
    }

    .result-side {
      border-top: 1px solid var(--color-border);
      padding: var(--space-5);
      font-size: var(--font-size-sm);
      color: var(--color-text-muted);
      background: color-mix(in srgb, var(--color-surface) 75%, var(--color-background) 25%);
    }

    @media (min-width: 900px) {
      .result-side {
        border-top: none;
        border-left: 1px solid var(--color-border);
      }
    }

    .result-side p {
      margin: 0 0 var(--space-2);
    }

    .result-card.empty {
      padding: var(--space-5);
    }

    .result-card.empty p {
      margin: 0;
      color: var(--color-text-muted);
    }
  </style>
</Layout>
