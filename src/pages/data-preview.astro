---
import Layout from '@layouts/Layout.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('master-library');
const datasets = all.filter((entry) => entry.data.category === 'dataset');
---

<Layout title="Data Preview" description="Preview of dataset entries from the master library">
  <section class="preview-shell">
    <h1>Data Preview</h1>
    <p class="intro">Listing datasets from the master library with native project blocks.</p>

    {datasets.length === 0 ? (
      <div class="empty-state">
        <p>No datasets found.</p>
      </div>
    ) : (
      <div class="preview-grid">
        {datasets.map((item) => (
          <article class="preview-card">
            <h2>{item.data.title}</h2>
            <p>{item.data.description}</p>
            {item.data.tags && item.data.tags.length > 0 && (
              <p class="meta">Tags: {item.data.tags.join(', ')}</p>
            )}
            {item.data.url && (
              <a href={item.data.url} target="_blank" rel="noopener noreferrer" class="button">Visit</a>
            )}
          </article>
        ))}
      </div>
    )}
  </section>

  <style>
    .preview-shell {
      display: grid;
      gap: var(--space-6);
    }

    .intro {
      color: var(--color-text-muted);
      max-width: 65ch;
    }

    .empty-state {
      border: 1px solid var(--color-border);
      background: var(--color-surface);
      border-radius: var(--radius-lg);
      padding: var(--space-6);
    }

    .empty-state p {
      margin: 0;
      color: var(--color-text-muted);
    }

    .preview-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }

    @media (min-width: 768px) {
      .preview-grid {
        grid-template-columns: 1fr 1fr;
      }
    }

    .preview-card {
      border: 1px solid var(--color-border);
      background: var(--color-surface);
      border-radius: var(--radius-lg);
      padding: var(--space-6);
      box-shadow: var(--shadow-sm);
      display: grid;
      gap: var(--space-4);
      align-content: start;
    }

    .preview-card h2 {
      margin: 0;
      font-size: var(--font-size-xl);
    }

    .preview-card p {
      margin: 0;
    }

    .meta {
      color: var(--color-text-muted);
      font-size: var(--font-size-sm);
    }

    .preview-card .button {
      justify-self: start;
    }
  </style>
</Layout>
